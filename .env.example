# ─────────────────────────────────────────────────────────────
#  AI Personal Finance Analyzer — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# App
ENVIRONMENT=development          # development | staging | production
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pfa_user:pfa_password@localhost:5432/pfa_db

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-access-token-secret-min-32-chars
JWT_REFRESH_SECRET_KEY=change-me-refresh-token-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_STATEMENTS_BUCKET=pfa-statements-dev
S3_REPORTS_BUCKET=pfa-reports-dev
S3_PRESIGNED_URL_EXPIRY=3600      # seconds

# ─── SQS Queue URLs ───────────────────────────────────────────
# Leave blank for local dev (workers skip gracefully).
# In production these are injected from SSM Parameter Store via the EC2 launch template.
SQS_STATEMENT_UPLOADED_URL=
SQS_STATEMENT_PARSED_URL=
SQS_TRANSACTIONS_CATEGORIZED_URL=
SQS_ANOMALIES_DETECTED_URL=
SQS_REPORT_SCHEDULE_URL=
SQS_REPORT_GENERATED_URL=
SQS_SUBSCRIPTION_EVENTS_URL=

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ─── SES (Email) ──────────────────────────────────────────────
SES_SENDER_EMAIL=noreply@yourdomain.com
SES_SENDER_NAME=AI Finance Analyzer

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
